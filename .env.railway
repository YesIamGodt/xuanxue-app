# 玄学互动平台 - Railway 部署配置
# 在 Railway 控制台 Variables 中设置以下环境变量

# AI 服务提供商：anthropic / openai / custom
AI_PROVIDER=anthropic

# Anthropic API Key（Claude AI）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key（备用）
OPENAI_API_KEY=sk-xxxxx

# OpenAI 兼容自定义 API（火山引擎等）
CUSTOM_API_KEY=xxxxx
CUSTOM_API_URL=https://api.minimax.chat/v1
CUSTOM_MODEL=MINIMAX/MiniMax-Text-01

# AI 参数
MAX_TOKENS=2048
TEMPERATURE=0.7
